{
  "name": "sandra-core",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {"node": ">=24.0.0"},
  "workspaces": [
    "apps/*",
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "wizard": "tsx scripts/wizard.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "drizzle-kit": "^0.22.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "undici": ">=6.24.0",
      "file-type": ">=21.3.1"
    }
  }
}
